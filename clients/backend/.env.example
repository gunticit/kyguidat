APP_NAME="Ký Gửi Đất Vuôn"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8015
APP_URL_SANDAT=https://app.khodat.com

FRONTEND_URL=http://localhost:3015

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker MySQL Configuration
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3321
DB_DATABASE=khodat
DB_USERNAME=khodat
DB_PASSWORD=khodat123

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

# Docker Redis Configuration
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@khodat.com"
MAIL_FROM_NAME="${APP_NAME}"

# Social Login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=${APP_URL}/api/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URL=${APP_URL}/api/auth/facebook/callback

ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_REDIRECT_URL=${APP_URL}/api/auth/zalo/callback

# Payment Gateways
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=${APP_URL}/api/payments/vnpay/callback

MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=${APP_URL}/api/payments/momo/callback
MOMO_NOTIFY_URL=${APP_URL}/api/payments/momo/notify

# Bank Transfer
BANK_NAME="Vietcombank"
BANK_ACCOUNT_NUMBER="1234567890"
BANK_ACCOUNT_NAME="CONG TY KHODAT"
BANK_BRANCH="Chi nhánh HCM"

# MinIO / S3 Configuration
# For local development, use MinIO container
AWS_ACCESS_KEY_ID=khodat_minio
AWS_SECRET_ACCESS_KEY=khodat_minio_secret
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=khodat
AWS_URL=http://localhost:9000/khodat
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# File Upload Settings
FILESYSTEM_DISK=public
MAX_UPLOAD_SIZE=10485760
MAX_IMAGE_WIDTH=2048
MAX_IMAGE_HEIGHT=2048
IMAGE_QUALITY=80
IMAGE_FORMAT=webp

# ============================================================
# CHATBOT + RAG (OpenAI) — xem plans/260417-1855-chatbot-hybrid-rag-implementation/
# ============================================================
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_API_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_URL=https://api.openai.com/v1/embeddings

# AI Quick Post Parser fallback (legacy)
AI_API_URL=http://103.90.226.30:20128/v1/responses
AI_API_MODEL=cx/gpt-5-codex-mini

# RAG toggle + provider
RAG_ENABLED=true
RAG_DEBUG=false
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536
RAG_EMBEDDING_BATCH_SIZE=50

# Retrieval tuning
RAG_TOP_K=10
RAG_FINAL_K=3
RAG_NUM_CANDIDATES=100
RAG_MIN_SCORE=0.0
RAG_BM25_WEIGHT=0.5
RAG_VECTOR_WEIGHT=0.5

# LLM generation
RAG_LLM_TEMPERATURE=0.4
RAG_LLM_MAX_TOKENS=800

# Elasticsearch (service name in docker-compose)
ELASTICSEARCH_URL=http://elasticsearch:9200
RAG_ES_INDEX=consignments_rag

# Voyage AI (optional alternative to OpenAI, better for Vietnamese)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# Self-hosted embedding (optional)
LOCAL_EMBEDDING_URL=http://embedding:8080/embed
